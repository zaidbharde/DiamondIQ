# Flask
SECRET_KEY=change-me-to-a-random-secret
FLASK_DEBUG=1

# Paths (defaults to Artifacts/ in project root)
DATABASE_PATH=
MODEL_PATH=
PREPROCESSOR_PATH=

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# --- AI Provider Configuration ---
# AI_PROVIDER can be:
#   auto   - automatically select from available API keys (OpenAI preferred, then Gemini)
#   openai - use OpenAI only
#   gemini - use Gemini only
AI_PROVIDER=auto

# OpenAI (requires OPENAI_API_KEY)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Google Gemini (requires GEMINI_API_KEY)
# GEMINI_API_KEY=
# GEMINI_MODEL=auto          # auto = discover best available vision model

# Cloudinary (for future image hosting)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
